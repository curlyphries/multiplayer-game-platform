# Server Configuration
PORT=4001
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:4000

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379

# Game Configuration
ROOM_EXPIRY_MINUTES=60
MAX_PLAYERS_PER_ROOM=8

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_MAX_AGE_DAYS=30
